{
  "name": "pet-salon",
  "version": "1.0.0",
  "description": "貳寶寵物美容工坊 — 犬貓美容定型化契約系統",
  "main": "electron/main.js",
  "author": "Pet Salon",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "install:all": "npm install && npm --prefix backend install && npm --prefix frontend install",
    "test:backend": "npm --prefix backend test",
    "test:frontend": "npm --prefix frontend test",
    "test": "npm run test:backend && npm run test:frontend",
    "build:frontend": "npm --prefix frontend run build",
    "start:backend": "node backend/src/index.js",
    "start": "npm run build:frontend && electron .",
    "dev": "electron .",
    "pack": "npm run build:frontend && electron-builder --dir",
    "dist": "npm run build:frontend && electron-builder"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.erbao.petsalon",
    "productName": "貳寶寵物美容工坊",
    "directories": {
      "output": "dist-electron"
    },
    "asar": true,
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "frontend/dist",
        "to": "frontend/dist"
      },
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "src/**/*",
          "assets/**/*",
          "package.json",
          "package-lock.json",
          ".puppeteerrc.cjs",
          "node_modules/**/*",
          "puppeteer-cache/**/*",
          "!tests/**/*",
          "!data/**/*",
          "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
          "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
          "!**/.bin/**",
          "!**/*.d.ts",
          "!**/*.md"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "compression": "store",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "貳寶寵物美容工坊",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "mac": {
      "icon": "build/icon-1024.png",
      "target": "dmg",
      "category": "public.app-category.business"
    }
  }
}
